# ============================================================
# Variáveis de Ambiente – TrocaFarma
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais no repositório.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<seu-projeto>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# ── Status Bot ──────────────────────────────────────────────
# URL do endpoint que recebe o card do anúncio como base64.
VITE_STATUS_BOT_URL=https://status.trocafarma.com/post-status

# Token de autenticação interno enviado no header x-internal-token.
VITE_STATUS_BOT_TOKEN=<seu-token-aqui>
